                                    "key": "id",
                                    "value": "1",
                                    "description": "Integer — unique plane identifier"
                                }
                            ]
                        },
                        "description": "Returns a single plane record by its integer ID.\n\n### Path Parameter\n| Name | Type | Required | Description |\n|------|------|----------|-------------|\n| id | integer | yes | Unique plane ID |\n\n### Response 200 OK\n```json\n{\n  \"id\": 1,\n  \"model\": \"Boeing 747\",\n  \"airline\": \"Ukraine International\"\n}\n```\n\n### Response 404 Not Found\n```json\n{\n  \"error\": \"Resource not found\",\n  \"message\": \"Plane with ID 99 does not exist\"\n}\n```"
                    },
                    "response": [
                        {
                            "name": "200 OK — Plane found",
                            "status": "OK",
                            "code": 200,
                            "header": [{ "key": "Content-Type", "value": "application/json" }],
