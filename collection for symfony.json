                {
                    "name": "Get plane by ID",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/api/planes/:id",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "planes", ":id"],
                            "variable": [
