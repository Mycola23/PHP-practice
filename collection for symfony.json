                {
                    "name": "Update plane (PUT — full update)",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"model\": \"Boeing 747-800 Updated\",\n    \"airline\": \"Ukraine International\"\n}",
                            "options": {
                                "raw": { "language": "json" }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/planes/:id",
                            "host": ["{{baseUrl}}"],
                            "path": ["api", "planes", ":id"],
                            "variable": [
                                {
                                    "key": "id",
                                    "value": "1",
                                    "description": "Integer — ID of the plane to update"
                                }
                            ]
                        },
                        "description": "Fully replaces all fields of an existing plane. Both `model` and `airline` should be provided.\n\nInternally uses `array_merge(existingPlane, requestData)` — fields not sent retain their previous values.\n\n### Path Parameter\n| Name | Type | Required | Description |\n|------|------|----------|-------------|\n| id | integer | yes | ID of the plane to update |\n\n### Request Body\n```json\n{\n  \"model\": \"Boeing 747-800 Updated\",\n  \"airline\": \"Ukraine International\"\n}\n```\n\n### Response 200 OK\n```json\n{\n  \"message\": \"Plane 1 updated successfully\",\n  \"data\": {\n    \"id\": 1,\n    \"model\": \"Boeing 747-800 Updated\",\n    \"airline\": \"Ukraine International\"\n  }\n}\n```\n\n### Response 400 Bad Request — empty body\n```json\n{ \"error\": \"No data provided\" }\n```\n\n### Response 404 Not Found\n```json\n{ \"error\": \"Plane not found\" }\n```"
                    },
                    "response": [
                        {
                            "name": "200 OK — Plane updated",
                            "status": "OK",
                            "code": 200,
                            "header": [{ "key": "Content-Type", "value": "application/json" }],
                            "_postman_previewlanguage": "json",
                            "originalRequest": {
                                "method": "PUT",
                                "header": [{ "key": "Content-Type", "value": "application/json" }],
                                "body": {
                                    "mode": "raw",
                                    "raw": "{\n    \"model\": \"Boeing 747-800 Updated\",\n    \"airline\": \"Ukraine International\"\n}"
                                },
                                "url": {
                                    "raw": "{{baseUrl}}/api/planes/1",
                                    "host": ["{{baseUrl}}"],
                                    "path": ["api", "planes", "1"]
                                }
                            },
                            "body": "{\n  \"message\": \"Plane 1 updated successfully\",\n  \"data\": {\n    \"id\": 1,\n    \"model\": \"Boeing 747-800 Updated\",\n    \"airline\": \"Ukraine International\"\n  }\n}"
                        },
                        {
                            "name": "400 Bad Request — No data provided",
                            "status": "Bad Request",
                            "code": 400,
                            "header": [{ "key": "Content-Type", "value": "application/json" }],
                            "_postman_previewlanguage": "json",
                            "body": "{\n  \"error\": \"No data provided\"\n}"
                        },
                        {
                            "name": "404 Not Found — Plane does not exist",
                            "status": "Not Found",
                            "code": 404,
                            "header": [{ "key": "Content-Type", "value": "application/json" }],
                            "_postman_previewlanguage": "json",
                            "body": "{\n  \"error\": \"Plane not found\"\n}"
                        }
                    ]
