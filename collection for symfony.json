                                    "key": "id",
                                    "value": "1",
                                    "description": "Integer — ID of the plane to partially update"
                                }
                            ]
                        },
                        "description": "Partially updates one or more fields of an existing plane. Only send the fields you want to change — unspecified fields keep their current values.\n\nHandled by the same controller action as PUT.\n\n### Request Body (partial)\n```json\n{\n  \"airline\": \"Wizz Air\"\n}\n```\n\n### Response 200 OK\n```json\n{\n  \"message\": \"Plane 1 updated successfully\",\n  \"data\": {\n    \"id\": 1,\n    \"model\": \"Boeing 747\",\n    \"airline\": \"Wizz Air\"\n  }\n}\n```"
                    },
                    "response": [
                        {
                            "name": "200 OK — Partial update applied",
                            "status": "OK",
                            "code": 200,
                            "header": [{ "key": "Content-Type", "value": "application/json" }],
                            "_postman_previewlanguage": "json",
                            "originalRequest": {
                                "method": "PATCH",
                                "header": [{ "key": "Content-Type", "value": "application/json" }],
                                "body": { "mode": "raw", "raw": "{\n    \"airline\": \"Wizz Air\"\n}" },
                                "url": {
                                    "raw": "{{baseUrl}}/api/planes/1",
                                    "host": ["{{baseUrl}}"],
                                    "path": ["api", "planes", "1"]
                                }
                            },
                            "body": "{\n  \"message\": \"Plane 1 updated successfully\",\n  \"data\": {\n    \"id\": 1,\n    \"model\": \"Boeing 747\",\n    \"airline\": \"Wizz Air\"\n  }\n}"
